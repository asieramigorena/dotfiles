#!/bin/bash
# Rofi bluetooth menu — toggle, connect/disconnect paired devices, open managers.

SELF="$0"
BT_ON=$(bluetoothctl show | grep -q "Powered: yes" && echo true || echo false)

toggle_bt() {
    if $BT_ON; then
        bluetoothctl power off
    else
        bluetoothctl power on
    fi
}

connect_device() {
    local mac="$1"
    if bluetoothctl info "$mac" | grep -q "Connected: yes"; then
        bluetoothctl disconnect "$mac"
    else
        bluetoothctl connect "$mac"
    fi
}

pair_device() {
    local mac="$1"
    bluetoothctl pair "$mac" && bluetoothctl connect "$mac"
}

build_menu() {
    if $BT_ON; then
        echo "󰂯  Bluetooth: ON  →  apagar"
    else
        echo "󰂲  Bluetooth: OFF  →  encender"
        return
    fi

    echo "---"

    while IFS= read -r line; do
        local mac name
        mac=$(echo "$line" | awk '{print $2}')
        name=$(echo "$line" | cut -d' ' -f3-)
        if bluetoothctl info "$mac" | grep -q "Connected: yes"; then
            echo "󰂱  $name  [conectado]  ::$mac"
        else
            echo "󰂴  $name  ::$mac"
        fi
    done < <(bluetoothctl devices)

    echo "---"
    echo "󱇧  Abrir Overskride"
    echo "󰂰  Buscar nuevos dispositivos"
}

scan_and_reopen() {
    notify-send "Bluetooth" "Buscando dispositivos..." -i bluetooth -t 8000
    # Scan for 8 seconds in background, then reopen the menu
    (bluetoothctl scan on > /dev/null 2>&1 & sleep 8; kill $! 2>/dev/null; "$SELF") &
}

# Show menu
CHOICE=$(build_menu | grep -v "^---$" | rofi -dmenu -p "Bluetooth" -i \
    -theme-str 'window {width: 400px;}' \
    -theme-str 'listview {lines: 8;}')

[ -z "$CHOICE" ] && exit 0

case "$CHOICE" in
    *"Bluetooth: ON"*)  toggle_bt ;;
    *"Bluetooth: OFF"*) toggle_bt ;;
    *"Abrir Overskride"*) overskride & ;;
    *"Buscar nuevos"*) scan_and_reopen ;;
    *)
        mac=$(echo "$CHOICE" | grep -oP '(?<=::)[0-9A-F:]+')
        if [ -n "$mac" ]; then
            if bluetoothctl info "$mac" | grep -qE "Paired: yes|Trusted: yes"; then
                connect_device "$mac"
            else
                pair_device "$mac"
            fi
        fi
        ;;
esac
